{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/geronimo-iia/agent-foundation/schemas/skills-index.json",
  "title": "Skills Hub Index",
  "description": "Schema for index.json generated by agent-hub-indexer for skill hubs",
  "type": "object",
  "required": ["type", "version", "entries", "metadata"],
  "properties": {
    "type": {
      "type": "string",
      "const": "skills"
    },
    "version": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "summary", "version", "path", "commit_hash", "last_updated", "tags"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" },
          "commit_hash": { "type": "string" },
          "last_updated": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "mcp_servers": {
            "type": "array",
            "description": "Bundled MCP servers in assets/ directory",
            "items": {
              "type": "object",
              "required": ["wasm_file", "wasm_hash"],
              "properties": {
                "wasm_file": {
                  "type": "string",
                  "description": "Relative path to WASM file (e.g., assets/tools.wasm)"
                },
                "wasm_hash": {
                  "type": "string",
                  "description": "SHA256 hash of WASM module",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "capabilities": {
                  "type": "object",
                  "description": "Required WASI capabilities",
                  "properties": {
                    "filesystem": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "network": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "env": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                "tools": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "List of tool names provided"
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generated_at", "commit_hash", "total_entries"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "commit_hash": { "type": "string" },
        "total_entries": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
