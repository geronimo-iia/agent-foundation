{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/geronimo-iia/agent-foundation/schemas/skills-index.json",
  "title": "Skills Hub Index",
  "description": "Schema for index.json generated by agent-hub-indexer for skill hubs",
  "type": "object",
  "required": ["type", "version", "entries", "metadata"],
  "properties": {
    "type": {
      "type": "string",
      "const": "skills"
    },
    "version": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "summary", "version", "path", "commit_hash", "last_updated", "tags"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" },
          "commit_hash": { "type": "string" },
          "last_updated": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generated_at", "commit_hash", "total_entries"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "commit_hash": { "type": "string" },
        "total_entries": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
